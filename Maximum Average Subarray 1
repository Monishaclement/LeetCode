class Solution {
    public double findMaxAverage(int[] nums, int k) {
    int n = nums.length;
    int sum =0;
    double avg = 0;
    double maxi = Integer.MIN_VALUE;
    for(int i=0;i<=n-k;i++)
    {
        sum =0;
      for(int j=i;j<i+k;j++)
      {
        sum = sum+nums[j];
      }
      avg = (double)sum/k;
      maxi = Math.max(avg,maxi);

    } 
    return (double) maxi;
    }
}
